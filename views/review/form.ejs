<div class="py-3 d-flex flex-column gap-3">
    <div>
        <label for="content">Content</label>
        <input type="text" class="form-control" name="content" value="<%= review?.content %>" required >
    </div>

    <div>
        <label for="rating">Quantity</label>
        <input type="number" class="form-control" name="rating" min="1" max="5" value="<%= review?.rating %>" >
    </div>
</div>